# NeuralBook Platform API Configuration
# Copy to .env and customize for your deployment

# ── Required ─────────────────────────────────────────────────────────────
# Comma-separated API keys for write endpoint authentication.
# Leave empty to disable auth (not recommended for production).
NBOOK_API_KEYS=

# ── Data ──────────────────────────────────────────────────────────────────
# Directory for platform data (books, patches, store)
NBOOK_DATA=./nbook_data

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use "*" for development only.
NBOOK_CORS_ORIGINS=*

# ── Server ────────────────────────────────────────────────────────────────
# Host and port for uvicorn
NBOOK_HOST=0.0.0.0
NBOOK_PORT=8000

# ── Encryption ────────────────────────────────────────────────────────────
# Seed for AES-256-GCM encryption (use `neuralbook keygen` to generate)
NEURALBOOK_ENCRYPTION_SEED=
