{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NeuralBook Trusted Keys Registry",
  "type": "object",
  "required": ["keys"],
  "properties": {
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key_id", "public_key_hex"],
        "properties": {
          "key_id": { "type": "string", "minLength": 1 },
          "public_key_hex": { "type": "string", "minLength": 64, "maxLength": 64 }
        }
      }
    }
  }
}

